generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A FreshRSS category/label the user has chosen to include in DailySpoon's
// daily edition. Feed management itself (adding/removing RSS URLs) stays
// entirely inside FreshRSS — DailySpoon only remembers which of FreshRSS's
// existing categories it should pull from.
model SelectedCategory {
  id         String   @id @default(cuid())
  freshrssId String   @unique // FreshRSS category stream id, e.g. "user/1005921/label/Tech"
  label      String // human-readable category name, e.g. "Tech"
  order      Int      @default(0) // display order of the column in EditionView, set from /admin/categories
  createdAt  DateTime @default(now())
  // Carte "Impression IA" dans /admin/categories : quand false, cette
  // catégorie (pourtant sélectionnée/incluse pour la récupération normale,
  // "En direct", recherche...) est totalement ignorée par la génération IA de
  // la première page (ni affichée sur la une, ni envoyée à la passe de
  // curation curateFrontPage) — ses articles du jour restent uniquement
  // consultables ailleurs dans l'app. Défaut true : rien ne change tant que
  // l'utilisateur ne décoche pas explicitement une catégorie.
  frontPageEnabled Boolean @default(true)
}

// A single FreshRSS feed (subscription) the user has explicitly excluded,
// regardless of its category — its articles are skipped when fetching, and
// any already-stored articles from it are purged everywhere in the app.
model ExcludedFeed {
  id         String   @id @default(cuid())
  freshrssId String   @unique // FreshRSS feed stream id (subscription "id"/origin.streamId)
  label      String
  createdAt  DateTime @default(now())
}

// A feed decorated with the "médaille" (war-honor-medal style badge) in
// /admin/categories. Articles from these feeds get a medal badge on their
// photo in EditionView, and are the pool the 3 "À la une" hero slots are
// picked from (most recent first).
model MedalFeed {
  id         String   @id @default(cuid())
  freshrssId String   @unique
  label      String
  createdAt  DateTime @default(now())
}

model Article {
  id             String    @id @default(cuid())
  freshrssItemId String    @unique // FreshRSS item id, used for dedupe
  feedId         String? // FreshRSS feed stream id (item.origin.streamId), for precise exclusion
  feedTitle      String // origin feed name as reported by FreshRSS
  categoryLabel  String? // FreshRSS category/tag this item came from
  sourceUrl      String
  sourceTitle    String
  sourceExcerpt  String?   @db.Text
  imageUrl       String? // illustration extracted from the feed's content/enclosure, if any
  publishedAt    DateTime?
  fetchedAt      DateTime  @default(now())

  // AI-processed fields
  processed      Boolean   @default(false)
  headline       String?
  summary        String?   @db.Text
  category       String? // final rubrique assigned by AI for the edition
  priorityScore  Int? // higher = more important, used to pick hero + ordering
  // Résumé court et percutant, spécifique à la une IA de la page d'accueil
  // (distinct de `summary`, plus développé, utilisé partout ailleurs — En
  // direct, favoris, archive). Produit par curateFrontPage (une passe par
  // génération, pas de coût supplémentaire) en même temps que priorityScore.
  // Null si la curation échoue ou si aucune clé IA n'est configurée : la une
  // retombe alors sur `summary` (voir FrontPageView).
  frontPageSummary String? @db.Text
  // true seulement si cet article est passé par un vrai appel IA
  // (processBatch/processBatchGemini) — false pour fallbackProcess, qu'il
  // s'agisse d'un article non "included", d'un dépassement du plafond
  // MAX_AI_ITEMS_PER_CATEGORY, de l'absence de clé IA ou de "Aspirer les
  // news" (forceNoAi). La une de la page d'accueil (page.tsx) et la passe de
  // curation (curateFrontPageScores) ne retiennent QUE aiRewritten=true : la
  // une doit être une vraie "impression IA", jamais du texte brut non
  // retravaillé — ces articles restent normalement visibles ailleurs (En
  // direct, recherche, archive).
  aiRewritten    Boolean   @default(false)

  favorite       Boolean   @default(false) // marqué favori depuis l'étoile shérif, page /favoris
  favoritedAt    DateTime? // date de mise en favori, affichée sur /favoris
  medal          Boolean   @default(false) // flux "médaillé" (voir MedalFeed) : badge sur la photo + éligible à la une

  // false si le flux est exclu ou la catégorie décochée dans /admin au
  // moment de la récupération (ou recalculé immédiatement si l'admin change
  // le réglage après coup). Ces articles restent en base — pour rester
  // trouvables par la recherche — mais sont exclus des vues normales
  // (accueil, En direct). Ils ne passent jamais par l'IA (toujours texte
  // brut), y compris si une clé Anthropic est configurée.
  included       Boolean   @default(true)

  edition        Edition?  @relation(fields: [editionId], references: [id])
  editionId      String?

  @@index([editionId])
  @@index([favorite])
  @@index([medal])
  @@index([included])
  // headline/summary/sourceTitle/feedTitle/category ont chacun un index GIN
  // trigram (pg_trgm), créé en SQL brut dans la migration
  // 20260716100000_article_search_trgm — non représentable ici sans le
  // preview feature postgresqlExtensions, volontairement omis pour ne pas
  // complexifier `prisma generate`. Accélère /api/articles/search (recherche
  // "contient" sur ces colonnes) à mesure que la table grossit.
}

model Edition {
  id          String    @id @default(cuid())
  // Jour calendaire — plus @unique : chaque régénération crée désormais sa
  // propre édition, conservée telle quelle (voir EditionArticle plus bas),
  // au lieu d'écraser la précédente du même jour.
  date        DateTime  @db.Date
  headline    String? // front-page headline
  status      String    @default("draft") // draft | published | failed
  generatedAt DateTime  @default(now())
  // Nombre total d'articles "included" du jour couvert par cette édition
  // (avant le plafond IA par catégorie, MAX_AI_ITEMS_PER_CATEGORY) — le vivier
  // de départ, à distinguer de snapshot.length qui ne compte que ceux
  // réellement réécrits par l'IA et retenus sur la une (voir generateEdition.ts).
  // null pour les éditions générées avant ce champ.
  sourcePoolCount Int?
  articles    Article[]
  snapshot    EditionArticle[]
}

// Photo figée du contenu de la une IA tel qu'il était EXACTEMENT au moment de
// cette génération précise. Nécessaire car Article (la table "vivante",
// utilisée par /direct, la recherche et les favoris) ne garde qu'une seule
// valeur d'"editionId" par article — à la génération suivante, un article
// déjà vu est réattribué à la NOUVELLE édition, ce qui viderait
// silencieusement les éditions précédentes de leurs articles si on ne
// gardait qu'Article comme source pour les archives. Une ligne EditionArticle
// n'est jamais modifiée ni réattribuée après coup : elle reste fidèle à
// l'impression du jour où elle a été créée, même si l'article vivant
// correspondant change ensuite de contenu ou change d'édition.
//
// Simple table de LIAISON (édition x article) — le contenu réel vit dans
// ArticleSnapshotContent, partagé entre toutes les éditions du jour où
// l'article n'a pas changé (voir plus bas). Sans ça, régénérer 5 fois dans la
// même journée dupliquait 5 fois le texte complet d'un article resté
// identique entre-temps.
model EditionArticle {
  id        String   @id @default(cuid())
  edition   Edition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  editionId String
  articleId String // référence informative vers l'Article vivant d'origine (pas de contrainte stricte : il peut depuis avoir été purgé)

  content   ArticleSnapshotContent @relation(fields: [contentId], references: [id])
  contentId String

  @@index([editionId])
  @@index([contentId])
}

// Contenu figé partagé, dédupliqué par empreinte (contentHash = hachage des
// champs ci-dessous) : deux régénérations le même jour où un article n'a
// strictement pas changé (même score IA, même résumé, même médaille...)
// pointent vers la MÊME ligne ici au lieu d'en dupliquer une copie complète
// à chaque fois. Dès qu'un seul champ change (nouvelle passe de curation IA,
// médaille retirée, image retrouvée...), une nouvelle ligne est créée pour
// cette nouvelle combinaison — le contenu ici n'est donc jamais modifié après
// coup, seulement créé une fois par combinaison distincte.
model ArticleSnapshotContent {
  id               String    @id @default(cuid())
  contentHash      String    @unique
  headline         String?
  summary          String?   @db.Text
  frontPageSummary String?   @db.Text
  category         String?
  priorityScore    Int?
  imageUrl         String?
  sourceUrl        String
  sourceTitle      String
  feedTitle        String
  categoryLabel    String?
  publishedAt      DateTime?
  medal            Boolean   @default(false)

  editionArticles  EditionArticle[]
}

// Runtime-configurable settings, editable from /admin/settings instead of
// redeploying with new environment variables. Single row (id = "singleton").
// Any field left null falls back to the matching environment variable —
// see src/lib/settings.ts.
model Settings {
  id                  String   @id @default("singleton")
  freshrssBaseUrl     String?
  freshrssUsername    String?
  freshrssApiPassword String?
  anthropicApiKey     String?
  anthropicModel      String?
  // Fournisseur IA utilisé pour la réécriture/résumé/priorisation des
  // articles : "anthropic" (défaut) ou "gemini". Change uniquement le
  // fournisseur utilisé quand une IA est effective — /direct ("Aspirer les
  // news") reste toujours sans IA quel que soit ce réglage.
  aiProvider          String?
  geminiApiKey        String?
  geminiModel         String?
  editionHour         Int?
  editionMinute       Int?
  editionTz           String?
  // false = génération automatique quotidienne (worker) désactivée ; dans ce
  // cas la page d'accueil affiche un bouton "Lancer l'impression du
  // journal" pour déclencher la génération à la main. null/true = planning
  // actif comme d'habitude, pas de bouton sur l'accueil.
  editionScheduleEnabled Boolean?
  retentionDays       Int? // rétention de l'historique en jours ; 0 = illimité ; null = défaut (730 = 2 ans)
  // Style d'écriture de l'IA qui réécrit/résume les articles : "normal"
  // (défaut, ton journalistique neutre) ou "ackboo" (ton sarcastique,
  // passif-agressif, cynique et drôle inspiré d'Ackboo/Canard PC). Sans
  // effet sur /direct, qui reste toujours sans IA.
  writingStyle        String?
  updatedAt           DateTime @default(now()) @updatedAt
}
