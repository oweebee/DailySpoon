generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A FreshRSS category/label the user has chosen to include in DailySpoon's
// daily edition. Feed management itself (adding/removing RSS URLs) stays
// entirely inside FreshRSS — DailySpoon only remembers which of FreshRSS's
// existing categories it should pull from.
model SelectedCategory {
  id         String   @id @default(cuid())
  freshrssId String   @unique // FreshRSS category stream id, e.g. "user/1005921/label/Tech"
  label      String // human-readable category name, e.g. "Tech"
  order      Int      @default(0) // display order of the column in EditionView, set from /admin/categories
  createdAt  DateTime @default(now())
}

// A single FreshRSS feed (subscription) the user has explicitly excluded,
// regardless of its category — its articles are skipped when fetching, and
// any already-stored articles from it are purged everywhere in the app.
model ExcludedFeed {
  id         String   @id @default(cuid())
  freshrssId String   @unique // FreshRSS feed stream id (subscription "id"/origin.streamId)
  label      String
  createdAt  DateTime @default(now())
}

// A feed decorated with the "médaille" (war-honor-medal style badge) in
// /admin/categories. Articles from these feeds get a medal badge on their
// photo in EditionView, and are the pool the 3 "À la une" hero slots are
// picked from (most recent first).
model MedalFeed {
  id         String   @id @default(cuid())
  freshrssId String   @unique
  label      String
  createdAt  DateTime @default(now())
}

model Article {
  id             String    @id @default(cuid())
  freshrssItemId String    @unique // FreshRSS item id, used for dedupe
  feedId         String? // FreshRSS feed stream id (item.origin.streamId), for precise exclusion
  feedTitle      String // origin feed name as reported by FreshRSS
  categoryLabel  String? // FreshRSS category/tag this item came from
  sourceUrl      String
  sourceTitle    String
  sourceExcerpt  String?   @db.Text
  imageUrl       String? // illustration extracted from the feed's content/enclosure, if any
  publishedAt    DateTime?
  fetchedAt      DateTime  @default(now())

  // AI-processed fields
  processed      Boolean   @default(false)
  headline       String?
  summary        String?   @db.Text
  category       String? // final rubrique assigned by AI for the edition
  priorityScore  Int? // higher = more important, used to pick hero + ordering

  favorite       Boolean   @default(false) // marqué favori depuis l'étoile shérif, page /favoris
  favoritedAt    DateTime? // date de mise en favori, affichée sur /favoris
  medal          Boolean   @default(false) // flux "médaillé" (voir MedalFeed) : badge sur la photo + éligible à la une

  edition        Edition?  @relation(fields: [editionId], references: [id])
  editionId      String?

  @@index([editionId])
  @@index([favorite])
  @@index([medal])
}

model Edition {
  id          String    @id @default(cuid())
  date        DateTime  @unique @db.Date // one edition per calendar day
  headline    String? // front-page headline
  status      String    @default("draft") // draft | published | failed
  generatedAt DateTime  @default(now())
  articles    Article[]
}

// Runtime-configurable settings, editable from /admin/settings instead of
// redeploying with new environment variables. Single row (id = "singleton").
// Any field left null falls back to the matching environment variable —
// see src/lib/settings.ts.
model Settings {
  id                  String   @id @default("singleton")
  freshrssBaseUrl     String?
  freshrssUsername    String?
  freshrssApiPassword String?
  anthropicApiKey     String?
  anthropicModel      String?
  editionHour         Int?
  editionMinute       Int?
  editionTz           String?
  updatedAt           DateTime @default(now()) @updatedAt
}
