# Postgres runs bundled in docker-compose.yml (service "db", with a
# persistent volume so data survives redeploys) — you don't need an
# external database. These three are optional (sensible defaults are
# baked into docker-compose.yml); set POSTGRES_PASSWORD at least if you
# want something other than the default.
POSTGRES_USER="dailyspoon"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="dailyspoon"

# Your existing FreshRSS instance — DailySpoon pulls articles from it via the
# Google Reader-compatible API instead of parsing RSS feeds itself.
# FRESHRSS_API_PASSWORD is the dedicated "API password" from FreshRSS's user
# settings (Profil > "Autoriser l'accès non authentifié via l'API" section),
# not necessarily your normal login password.
FRESHRSS_BASE_URL="https://freshrss.example.com"
FRESHRSS_USERNAME="ton-identifiant-freshrss"
FRESHRSS_API_PASSWORD="ton-mot-de-passe-api-freshrss"

# AI provider used to rewrite/summarize/categorize/prioritize articles.
# Leave empty to run in fallback mode (no rewriting, naive categorization).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# Single-admin auth for /admin (choix des catégories FreshRSS, régénération
# manuelle). Pas de compte utilisateur : juste ce mot de passe.
ADMIN_PASSWORD="change-me"
ADMIN_SECRET="a-long-random-string"

# Shared secret the worker/cron caller uses to hit /api/cron/generate
# (leave matching CRON_SECRET below if you trigger generation manually via curl).
CRON_SECRET="another-long-random-string"

# Worker (self-hosted daily scheduler) settings.
EDITION_HOUR=6
EDITION_MINUTE=0
EDITION_TZ="Europe/Paris"
RUN_ON_START=false

# --- Optional integrations (all also settable in /admin/settings; these env
# --- vars are only fallbacks used when the matching field is left empty there).

# Telegram push notifications: a bot token (@BotFather) and the target
# chat/channel id. Feeds are opted in per-feed via the "notification" checkbox
# in /admin/categories.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Wallabag (self-hosted read-it-later): favoriting an article sends its link to
# Wallabag (tagged "DailySpoon"). Wallabag has no simple API key — it needs an
# OAuth2 password grant: instance URL + a client id/secret (create an API client
# in Wallabag) + your Wallabag account username/password.
WALLABAG_BASE_URL=""
WALLABAG_CLIENT_ID=""
WALLABAG_CLIENT_SECRET=""
WALLABAG_USERNAME=""
WALLABAG_PASSWORD=""

# External RSS reader: DailySpoon exposes a FreshRSS-compatible Google Reader API
# at /api/greader.php, so any FreshRSS/Google Reader-compatible reader can connect.
# In the reader, add a "FreshRSS" account pointed at this app's URL, login
# "dailyspoon", and this code as the password. Normally you generate an 8-digit
# code from /admin/settings instead of setting this — this env var is only a
# fallback. Leaving it empty also lets the admin password be accepted.
GREADER_API_PASSWORD=""
