# Postgres connection string (your own RDS / managed Postgres instance)
DATABASE_URL="postgresql://user:password@host:5432/dailyspoon?schema=public"

# Your existing FreshRSS instance — DailySpoon pulls articles from it via the
# Google Reader-compatible API instead of parsing RSS feeds itself.
# FRESHRSS_API_PASSWORD is the dedicated "API password" from FreshRSS's user
# settings (Profil > "Autoriser l'accès non authentifié via l'API" section),
# not necessarily your normal login password.
FRESHRSS_BASE_URL="https://freshrss.example.com"
FRESHRSS_USERNAME="ton-identifiant-freshrss"
FRESHRSS_API_PASSWORD="ton-mot-de-passe-api-freshrss"

# AI provider used to rewrite/summarize/categorize/prioritize articles.
# Leave empty to run in fallback mode (no rewriting, naive categorization).
ANTHROPIC_API_KEY=